# Local development against DynamoDB Local (docker compose up -d dynamodb-local).
# Load it with:  export $(grep -v '^#' .env.local | xargs)
# or copy to .env:  cp .env.local .env
ENVIRONMENT="development"
DEBUG=true

AWS_REGION="us-east-1"
DYNAMODB_TABLE_NAME="items"
DYNAMODB_ENDPOINT_URL="http://localhost:8000"
AUTO_CREATE_TABLE=true

# DynamoDB Local ignores these, but boto3 requires credentials to be present.
AWS_ACCESS_KEY_ID="local"
AWS_SECRET_ACCESS_KEY="local"
