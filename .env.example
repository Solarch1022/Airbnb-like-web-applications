# Application settings
APP_NAME="Example Python Backend"
ENVIRONMENT="development"
DEBUG=true

# Server
HOST="0.0.0.0"
PORT=8000

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS="*"

# AWS DynamoDB
AWS_REGION="us-east-1"
DYNAMODB_TABLE_NAME="items"
# Optional: set for DynamoDB Local, leave unset to use real AWS.
# DYNAMODB_ENDPOINT_URL="http://localhost:8000"
# Standard AWS credential env vars are also read by boto3:
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
